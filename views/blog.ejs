<!DOCTYPE html>
<html lang="en">

  <head>
  <%- include('head') %>
    <title>Home</title>
</head>

<body>
  <%- include('navbar') %>
    <div>
        <div class="card" style="width: 100vw;">
  <img src="<%= blog.image %>" class="card-img-top" alt="...">
  <div class="card-body">
    <h2><%= blog.title %></h2>
    <pre class="card-text"><%= blog.body %></pre>
    <p><strong>Blog By: <%= blog.createdBy.name %></strong></p>
    <b>CreatedAt: <%= blog.createdAt %></b>
  </div>
</div>

<div>
    <h3>Comments</h3>
    <div>
     <% if (locals.comments){ 
      comments.forEach((comment) =>{ %>

      <div>
        <p><strong><%= comment.userId.name %></strong></p>
        <p><%= comment.comment %></p>
      </div>

    <% } )} %>
    </div>
    <% if (locals.user){ %>
        <form action="/blog/comments/<%= blog._id %>" method="post">
            <textarea name="comment" id=""></textarea>
            <button type="submit">Send</button>
        </form>
   <% } %>
</div>
    </div>

   <%- include('script') %>

<html>
<head>
    <title><%= blog.title %></title>
</head>
<body>

    <h1><%= blog.title %></h1>

    <div>
        <img src="<%= blog.image %>" alt="Blog Image" width="400">
    </div>

    <p>
        <strong>Posted on:</strong> 
        <%= blog.createdAt.toDateString() %>
    </p>

    <% if (blog.createdBy) { %>
        <p>s
            <strong>Author:</strong> 
            <%= blog.createdBy.name %>
        </p>
    <% } %>

    <hr>

    <p>
        <%= blog.body %>
    </p>


</body>
</html>